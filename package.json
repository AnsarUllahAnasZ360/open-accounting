{
  "name": "openbooks",
  "version": "0.0.0",
  "private": true,
  "license": "AGPL-3.0-only",
  "packageManager": "pnpm@10.26.2",
  "pnpm": {
    "overrides": {
      "@types/react": "19.2.17",
      "@types/react-dom": "19.2.3",
      "react": "19.2.4",
      "react-dom": "19.2.4"
    }
  },
  "scripts": {
    "dev": "pnpm --filter @openbooks/web dev",
    "setup": "node scripts/setup.mjs",
    "dev:full": "node scripts/dev-full.mjs",
    "build": "pnpm --filter @openbooks/web build",
    "lint": "pnpm --filter @openbooks/web lint",
    "typecheck": "pnpm --filter @openbooks/web typecheck",
    "typecheck:convex": "tsc -p convex/tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:unit": "vitest run --passWithNoTests",
    "test:e2e": "playwright test",
    "seed:demo": "node scripts/seed-demo.mjs",
    "receipts:fixtures": "node scripts/generate-receipt-fixtures.mjs",
    "stripe:webhook:register": "node scripts/register-stripe-webhook.mjs",
    "preflight": "node scripts/preflight.mjs",
    "check:env-docs": "node scripts/check-env-docs.mjs",
    "scan:secrets": "node scripts/scan-secrets.mjs",
    "security:gitleaks": "gitleaks git --config .gitleaks.toml --redact -v",
    "security:audit": "pnpm audit --prod",
    "verify": "pnpm typecheck && pnpm typecheck:convex && pnpm lint && pnpm build && pnpm test:unit",
    "ci": "pnpm verify && pnpm test:e2e",
    "convex:dev": "convex dev",
    "convex:deploy": "convex deploy"
  },
  "devDependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.1066.0",
    "@edge-runtime/vm": "^5.0.0",
    "@playwright/test": "^1.60.0",
    "@types/node": "^20.19.42",
    "convex-test": "^0.0.53",
    "next": "16.2.7",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "typescript": "^5.9.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "@ai-sdk/amazon-bedrock": "^4.0.116",
    "@ai-sdk/anthropic": "^3.0.84",
    "@ai-sdk/gateway": "^3.0.130",
    "@ai-sdk/openai": "^3.0.71",
    "@ai-sdk/openai-compatible": "^2.0.50",
    "@auth/core": "^0.37.0",
    "@convex-dev/agent": "^0.6.3",
    "@convex-dev/auth": "^0.0.93",
    "ai": "^6.0.202",
    "convex": "^1.40.0",
    "convex-helpers": "^0.1.119",
    "jose": "6.2.3"
  }
}
