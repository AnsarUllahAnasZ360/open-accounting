{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/ai/**",
              "components/core/**",
              "components/data/**",
              "components/forms/**",
              "components/navigation/**",
              "ui_kits/openbooks/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Geist|Geist Mono))/i]",
        "message": "Font not provided by the design system. Available: Geist, Geist Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='Amount'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|colored|signed|abbreviate|decimals|currency|size|weight|style|className|key|ref|className|style|children)$/]",
        "message": "<Amount> doesn't accept that prop. Declared props: value, colored, signed, abbreviate, decimals, currency, size, weight, style, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='AskAI'] > JSXAttribute > JSXIdentifier[name!=/^(?:placeholder|suggestions|onSubmit|style|key|ref|className|style|children)$/]",
        "message": "<AskAI> doesn't accept that prop. Declared props: placeholder, suggestions, onSubmit, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|icon|children|className|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: variant, icon, children, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:default|secondary|outline|destructive|positive|negative|warning|info|ai)$/]",
        "message": "<Badge> variant must be one of 'default' | 'secondary' | 'outline' | 'destructive' | 'positive' | 'negative' | 'warning' | 'info' | 'ai'."
      },
      {
        "selector": "JSXOpeningElement[name.name='BarChart'] > JSXAttribute > JSXIdentifier[name!=/^(?:data|height|positiveColor|negativeColor|showLabels|formatValue|key|ref|className|style|children)$/]",
        "message": "<BarChart> doesn't accept that prop. Declared props: data, height, positiveColor, negativeColor, showLabels, formatValue."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|icon|iconEnd|disabled|onClick|children|className|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, icon, iconEnd, disabled, onClick, children, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:default|outline|secondary|ghost|destructive|link)$/]",
        "message": "<Button> variant must be one of 'default' | 'outline' | 'secondary' | 'ghost' | 'destructive' | 'link'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:default|sm|lg|icon|icon-sm)$/]",
        "message": "<Button> size must be one of 'default' | 'sm' | 'lg' | 'icon' | 'icon-sm'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:size|children|className|style|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: size, children, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:default|sm)$/]",
        "message": "<Card> size must be one of 'default' | 'sm'."
      },
      {
        "selector": "JSXOpeningElement[name.name='EmptyState'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|title|description|action|key|ref|className|style|children)$/]",
        "message": "<EmptyState> doesn't accept that prop. Declared props: icon, title, description, action."
      },
      {
        "selector": "JSXOpeningElement[name.name='Icon'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|size|strokeWidth|color|style|className|key|ref|className|style|children)$/]",
        "message": "<Icon> doesn't accept that prop. Declared props: name, size, strokeWidth, color, style, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|placeholder|value|defaultValue|onChange|type|disabled|className|style|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: icon, placeholder, value, defaultValue, onChange, type, disabled, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='PageHeader'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|description|actions|style|key|ref|className|style|children)$/]",
        "message": "<PageHeader> doesn't accept that prop. Declared props: title, description, actions, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ReviewItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:counterparty|date|amount|account|question|options|onChoose|onSkip|style|key|ref|className|style|children)$/]",
        "message": "<ReviewItem> doesn't accept that prop. Declared props: counterparty, date, amount, account, question, options, onChoose, onSkip, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Select'] > JSXAttribute > JSXIdentifier[name!=/^(?:options|value|defaultValue|onChange|placeholder|disabled|className|style|key|ref|className|style|children)$/]",
        "message": "<Select> doesn't accept that prop. Declared props: options, value, defaultValue, onChange, placeholder, disabled, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='SideNav'] > JSXAttribute > JSXIdentifier[name!=/^(?:items|activeId|onSelect|logoSrc|footerItems|style|key|ref|className|style|children)$/]",
        "message": "<SideNav> doesn't accept that prop. Declared props: items, activeId, onSelect, logoSrc, footerItems, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Sparkline'] > JSXAttribute > JSXIdentifier[name!=/^(?:data|width|height|color|fill|key|ref|className|style|children)$/]",
        "message": "<Sparkline> doesn't accept that prop. Declared props: data, width, height, color, fill."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|detail|icon|trend|trendVariant|children|key|ref|className|style|children)$/]",
        "message": "<StatCard> doesn't accept that prop. Declared props: label, value, detail, icon, trend, trendVariant, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatCard'] > JSXAttribute[name.name='trendVariant'] > Literal[value!=/^(?:default|secondary|outline|positive|negative|warning|info|ai)$/]",
        "message": "<StatCard> trendVariant must be one of 'default' | 'secondary' | 'outline' | 'positive' | 'negative' | 'warning' | 'info' | 'ai'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Switch'] > JSXAttribute > JSXIdentifier[name!=/^(?:checked|defaultChecked|onCheckedChange|size|disabled|className|key|ref|className|style|children)$/]",
        "message": "<Switch> doesn't accept that prop. Declared props: checked, defaultChecked, onCheckedChange, size, disabled, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='Switch'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:default|sm)$/]",
        "message": "<Switch> size must be one of 'default' | 'sm'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Table'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|className|key|ref|className|style|children)$/]",
        "message": "<Table> doesn't accept that prop. Declared props: children, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tabs'] > JSXAttribute > JSXIdentifier[name!=/^(?:defaultValue|value|onValueChange|children|className|key|ref|className|style|children)$/]",
        "message": "<Tabs> doesn't accept that prop. Declared props: defaultValue, value, onValueChange, children, className."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
