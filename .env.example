# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="OpenBooks"

# Owner / access (invite-only auth; M2 seeds the owner account from these)
OWNER_EMAIL=
OWNER_PASSWORD=

# Convex
NEXT_PUBLIC_CONVEX_URL=
CONVEX_URL=
CONVEX_SITE_URL=
CONVEX_DEPLOYMENT=

# Convex Auth
# SITE_URL, JWT_PRIVATE_KEY, and JWKS must also be set in the Convex
# deployment environment. v1 auth is password-based (invite-only);
# PLUNK_SECRET_KEY is optional and used for request-access notifications.
SITE_URL=http://localhost:3000
JWT_PRIVATE_KEY=
JWKS=

# Plunk
PLUNK_API_BASE_URL=https://api.plunk.zikrainfotech.com
NEXT_PUBLIC_PLUNK_PUBLIC_KEY=
PLUNK_SECRET_KEY=
PLUNK_FROM_EMAIL=
PLUNK_FROM_NAME="OpenBooks"

# AI provider — bring your own key. The canonical catalog lives in
# convex/aiCatalog.ts (14 providers). Set AI_PROVIDER to one of:
#   gateway | openai | anthropic | google | bedrock | azure | groq |
#   deepseek | mistral | moonshot | xai | fireworks | ollama | openai_compatible
# Only the env block for your chosen provider is required (preflight is
# provider-aware: an OpenAI self-hoster is never asked for AWS keys).
AI_PROVIDER=bedrock
AI_MODEL=
AI_TEMPERATURE=0.2
AI_MAX_OUTPUT_TOKENS=2048

# AI — AWS Bedrock credentials (when AI_PROVIDER=bedrock)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=

# AI — OpenAI (when AI_PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=

# AI — other catalog providers (set the key for the provider you chose above)
ANTHROPIC_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
AI_GATEWAY_API_KEY=
GROQ_API_KEY=
DEEPSEEK_API_KEY=
MISTRAL_API_KEY=
MOONSHOT_API_KEY=
XAI_API_KEY=
FIREWORKS_API_KEY=
# Azure OpenAI (AI_PROVIDER=azure): key + your resource base URL
AZURE_API_KEY=
AZURE_BASE_URL=
# Ollama (AI_PROVIDER=ollama): local server URL, no key needed
OLLAMA_BASE_URL=http://localhost:11434/v1
# OpenAI-compatible custom gateway (AI_PROVIDER=openai_compatible)
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_BASE_URL=
# Optional: embeddings model name (memory/recall stage)
AI_EMBEDDINGS_MODEL=

# OpenBooks encrypted UI vault — required before saving Plaid, Stripe, or AI
# provider keys in the app. Generate a long random value and keep it server-side.
OPENBOOKS_SECRET_ENCRYPTION_KEY=
# Backward-compatible legacy name; prefer OPENBOOKS_SECRET_ENCRYPTION_KEY.
OPENBOOKS_TOKEN_ENCRYPTION_KEY=

# Real-data guard — leave blank unless you intentionally allow live Plaid/Stripe
# setup and sync in this deployment.
OPENBOOKS_REAL_TEST_LIVE_CONNECTORS=

# Plaid — optional legacy env fallback. New self-host setup should save Plaid
# credentials from Settings → Connections → Setup.
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox
PLAID_OAUTH_REDIRECT_URI=
PLAID_WEBHOOK_URL=

# Stripe — optional legacy env fallback. New self-host setup should save a
# restricted key and webhook signing secret from Settings → Connections → Setup.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
