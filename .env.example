# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="OpenBooks"

# Owner / access (invite-only auth; M2 seeds the owner account from these)
OWNER_EMAIL=
OWNER_PASSWORD=

# Convex
NEXT_PUBLIC_CONVEX_URL=
CONVEX_URL=
CONVEX_SITE_URL=
CONVEX_DEPLOYMENT=

# Convex Auth
# SITE_URL, JWT_PRIVATE_KEY, and JWKS must also be set in the Convex
# deployment environment. v1 auth is password-based (invite-only);
# PLUNK_SECRET_KEY is optional and used for request-access notifications.
SITE_URL=http://localhost:3000
JWT_PRIVATE_KEY=
JWKS=

# Plunk
PLUNK_API_BASE_URL=https://api.plunk.zikrainfotech.com
NEXT_PUBLIC_PLUNK_PUBLIC_KEY=
PLUNK_SECRET_KEY=
PLUNK_FROM_EMAIL=
PLUNK_FROM_NAME="OpenBooks"

# AI (v1 default: bedrock — see docs/initiation/access-and-questions.md §1)
# Options: bedrock | anthropic | openai | google | ollama
AI_PROVIDER=bedrock
AI_MODEL=
AI_EMBEDDINGS_MODEL=amazon.titan-embed-text-v2:0
AI_TEMPERATURE=0.2
AI_MAX_OUTPUT_TOKENS=2048

# AI — AWS Bedrock credentials (when AI_PROVIDER=bedrock)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=

# AI — OpenAI-compatible (when AI_PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=

# Plaid — SANDBOX keys only for this goal (dashboard.plaid.com → Developers → Keys)
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox

# Stripe — TEST-MODE key only for this goal (sk_test_ / rk_test_)
# STRIPE_WEBHOOK_SECRET may be left blank; it is captured when the webhook
# endpoint is registered during the run.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
